# Copy to `.env` in the repo root (same folder as Dockerfile). Do not commit a real `.env` to git.
# Docker / Cloud Run: the production image copies `.env` into the container; see docs/CLOUD_RUN_DEPLOY.md.
# On Cloud Run, set GCP_PROJECT below and omit GOOGLE_APPLICATION_CREDENTIALS — use the Cloud Run service account.

# GCP / Vertex AI (project is read from service account JSON if GCP_PROJECT not set)
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp-key.json
# GCP_PROJECT=optional-override
GCP_LOCATION=us-central1
# Exact models used: both are Vertex AI (no separate purchase for embedding)
VERTEX_MODEL=gemini-2.5-flash
VERTEX_EMBEDDING_MODEL=text-embedding-004

# SharePoint (MSAL app registration)
SHAREPOINT_CLIENT_ID=your-client-id
SHAREPOINT_CLIENT_SECRET=your-client-secret
SHAREPOINT_TENANT_ID=your-tenant-id
SHAREPOINT_SITE_URL=https://your-tenant.sharepoint.com/sites/YourSite
SHAREPOINT_DRIVE_PATH=Shared Documents/YourFolder
# Optional: if your folder is in a non-default document library, set this (e.g. from --sharepoint-browse-interactive when it prints SHAREPOINT_DRIVE_ID).
# SHAREPOINT_DRIVE_ID=b!xxxxx...
SHAREPOINT_DRIVE_PATH=

# Optional: GCP Cloud Storage — same credentials as Vertex. PDF source is SharePoint only.
# If set, we upload sow_results.xlsx to the bucket. PDFs are not uploaded (only sent to Gemini for OCR).
# Use the bucket name only (e.g. my-sow-bucket), not gs:// or a full URL.
# GCS_OUTPUT_BUCKET=your-bucket-name

# Optional: local data dir (default: ./data)
DATA_DIR=./data

# Optional: monitor SharePoint every N minutes and run extraction when new/changed files exist (0 = disabled).
# EXTRACTION_MONITOR_INTERVAL_MINUTES=30

# Delegated user-login session secret (required in production; set a long random value).
SESSION_SECRET=replace-with-long-random-secret

# Optional: comma-separated list of allowed frontend origins (default '*' for dev).
# CORS_ALLOWED_ORIGINS=https://your-app-domain

# Docker: path to GCP key on host (mounted into container)
# GCP_CREDENTIALS_PATH=./secrets/gcp-key.json
